{
  "name": "template-nextjs-ts",
  "version": "1.0.0",
  "private": true,
  "description": "✨ Next.js 16+ full stack template with MongoDB, dynamic OpenAPI generation, and type-safe auto-documentation. Features route-centric architecture with co-located types and zero-configuration API discovery. 🚀",
  "homepage": "https://github.com/YousifAbozid/template-nextjs-ts#readme",
  "bugs": {
    "url": "https://github.com/YousifAbozid/template-nextjs-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YousifAbozid/template-nextjs-ts.git"
  },
  "license": "MIT",
  "author": {
    "name": "Yousif Abozid",
    "email": "yousif.abozid@yahoo.com",
    "url": "https://github.com/YousifAbozid"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run api:generate && next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint app --cache --cache-location .eslintcache",
    "lint:fix": "eslint app --fix --cache --cache-location .eslintcache",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "fix-all": "npm run lint:fix && npm run format",
    "test": "npm run format:check && npm run lint && npm run type-check",
    "upgrade": "npx npm-check-updates -u && npm install",
    "prepare": "husky",
    "api:generate": "node scripts/generate-openapi.js",
    "api:watch": "node scripts/watch-openapi.js",
    "api:dev": "concurrently \"npm run dev\" \"npm run api:watch\""
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "mongoose": "^9.0.0",
    "next": "16.0.7",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "reflect-metadata": "^0.2.2",
    "use-local-storage": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "openapi-typescript": "^7.10.1",
    "prettier": "3.7.4",
    "swagger-typescript-api": "^13.2.16",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --cache --cache-location .eslintcache --no-warn-ignored",
      "prettier --write"
    ],
    "*.{css,scss,less}": [
      "prettier --write"
    ]
  }
}
