{
  "name": "template-nextjs-ts",
  "version": "1.0.0",
  "private": true,
  "description": "🚀 Production-ready Next.js 16+ full-stack template with TypeScript, MongoDB, Tailwind CSS v4, and comprehensive tooling. Features Zod-based schemas with auto-generated OpenAPI documentation, Orval SDK with React Query hooks, functional architecture with zero decorators, dark mode support, custom UI components with Framer Motion, and complete developer experience with ESLint, Prettier, and Husky. Perfect for building scalable web applications with modern functional patterns. ✨",
  "homepage": "https://github.com/YousifAbozid/template-nextjs-ts#readme",
  "bugs": {
    "url": "https://github.com/YousifAbozid/template-nextjs-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YousifAbozid/template-nextjs-ts.git"
  },
  "license": "MIT",
  "author": {
    "name": "Yousif Abozid",
    "email": "yousif.abozid@yahoo.com",
    "url": "https://github.com/YousifAbozid"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run api:generate && npm run api:sdk && npm run type-check && next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint app --cache --cache-location .eslintcache",
    "lint:fix": "eslint app --fix --cache --cache-location .eslintcache",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "fix-all": "npm run lint:fix && npm run format",
    "test": "npm run format:check && npm run lint && npm run type-check",
    "upgrade": "npx npm-check-updates -u && npm install",
    "prepare": "husky",
    "api:generate": "tsx scripts/generate-openapi.mjs",
    "api:sdk": "npx orval",
    "api:dev": "concurrently \"npm run dev\" \"npm run api:watch\"",
    "api:watch": "concurrently \"tsx scripts/watch-openapi.mjs\" \"npx orval --watch\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.13.2",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.556.0",
    "mongoose": "^9.0.1",
    "next": "16.0.9",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.68.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.2.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "orval": "^7.17.0",
    "prettier": "3.7.4",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --cache --cache-location .eslintcache --no-warn-ignored",
      "prettier --write"
    ],
    "*.{css,scss,less}": [
      "prettier --write"
    ]
  }
}
